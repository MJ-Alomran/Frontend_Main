@{
    ViewData["Title"] = "تسجيل دخول الطالب";
}

<div class="login-container">
    <div class="login-card">
        <!-- العنوان -->
        <h1 class="login-title">تسجيل دخول الطالب</h1>
        <p class="login-subtitle">أدخل بيانات حسابك للدخول</p>

        <!-- نموذج التسجيل -->
        <form method="post" action="/Student/Login" class="login-form">
            
            <!-- حقل البريد الإلكتروني -->
            <div class="form-group">
                <label for="email" class="form-label">
                    <i class="fas fa-envelope"></i> البريد الإلكتروني
                </label>
                <input type="email"
                       id="email"
                       name="email"
                       class="form-control"
                       placeholder="أدخل بريدك الإلكتروني"
                       required>
            </div>

            <!-- حقل كلمة المرور -->
            <div class="form-group">
                <label for="password" class="form-label">
                    <i class="fas fa-lock"></i> كلمة المرور
                </label>
                <input type="password"
                       id="password"
                       name="password"
                       class="form-control"
                       placeholder="أدخل كلمة المرور"
                       required>
            </div>

            <!-- زر الدخول -->
            <button type="submit" class="btn btn-login">
                <i class="fas fa-sign-in-alt"></i> دخول
            </button>
        </form>

        <!-- رابط التسجيل الجديد -->
        <div class="login-footer">
            <p>
                ليس لديك حساب؟
                <a href="/Student/Register" class="register-link">سجل الآن</a>
            </p>
        </div>
    </div>
</div>
